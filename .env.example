# ═══════════════════════════════════════════════
#  TradingView Signals Bot — Configuración
# ═══════════════════════════════════════════════
#
# PASO 1: Crea un bot en Telegram
#   → Abre @BotFather en Telegram
#   → Envía /newbot
#   → Copia el token que te da y pégalo abajo
#
# PASO 2: Obtén tu Chat ID
#   → Envía un mensaje a tu bot
#   → Abre: https://api.telegram.org/bot<TOKEN>/getUpdates
#   → Busca "chat":{"id": XXXXXXX}  ← ese es tu Chat ID
#
# PASO 3: Configura y corre el bot
#   → node bot/signals-bot.js

# ── Telegram ────────────────────────────────────
TELEGRAM_TOKEN=AQUI_TU_TOKEN_DE_BOTFATHER
TELEGRAM_CHAT=AQUI_TU_CHAT_ID

# ── TradingView CDP ─────────────────────────────
CDP_PORT=9222

# ── Bot ─────────────────────────────────────────
# Segundos entre cada lectura del chart (default: 30)
POLL_INTERVAL=30

# DRY_RUN=true → solo loguea señales, no envía Telegram
DRY_RUN=false

# Nombre del indicador en TradingView
# (debe coincidir con el script en strategies/neural_matrix_pro.pine)
INDICATOR_NAME=Neural Matrix Pro [Bot]
